# Required for live AI mediation (not needed for Demo mode with mock data)
OPENAI_API_KEY=

# Public site URL — used for Stripe redirects, share links (WhatsApp/FB/email), and Open Graph previews
# Dev: http://localhost:3000  Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=

# Stripe — omit to use mock checkout (unlocks in dev without charging)
STRIPE_SECRET_KEY=

# Free-for-all mode. When `true`, every feature is unlocked for everyone:
# unlimited mediated messages, resolution generator, insight report,
# prepare-conversation, business mode. Credit counters and paywall CTAs are
# hidden. Leave empty (or set to `false`) to re-enable paywalls. Stripe code
# remains wired up either way — this is a runtime flag, not a code change.
BRIDGE_FREE_MODE=

# Persistence. Leave empty for local dev (rooms live in process memory and
# are lost on restart). On Render (or any host) set this to a writable path
# on a persistent disk to use the SQLite-backed store, e.g. /data/bridge.db
# See README "Deploy" section for Render disk setup.
BRIDGE_DB_PATH=
